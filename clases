
import pandas as pd 
import matplotlib.pyplot as plt
import numpy as np
from scipy.io import loadmat, whosmat

#clase para CSV (SIATA) 
class ArchivoSIATA:
    def __init__(self, ruta):
        self.data = pd.read_csv(ruta)
        print("Archivo CSV cargado correctamente.")
    
    #informa y describe
    def info_basica(self):
        print("Información básica:")
        print(self.data.info())
        print("\nDescripción estadística:")
        print(self.data.describe())

    #SUBPLOTS
    def graficos(self, columna):
        fig, axs = plt.subplots(3, 1, figsize=(8, 10))

        self.data[columna].plot(ax=axs[0], title="Plot")
        self.data.boxplot(column=columna, ax=axs[1])
        self.data[columna].hist(ax=axs[2])

        plt.tight_layout()
        plt.savefig("graficos/siata_graficos.png")
        plt.show()

    #operaciones 
    def operaciones(self, col1, col2):
        self.data[col1+"_apply"] = self.data[col1].apply(lambda x: x*2)
        self.data[col1+"_map"] = self.data[col1].map(lambda x: x + 10)
        self.data["suma"] = self.data[col1] + self.data[col2]
        print("Operaciones realizadas")

    #remuestreo
    def remuestreo(self, col_fecha, col_valor): 
        self.data[col_fecha] = pd.to_datetime(self.data[col_fecha])
        self.data.set_index(col_fecha, inplace=True)
        
        diario = self.data[col_valor].resample('D').mean()
        mensual= self.data[col_valor].resample('M').mean()
        trimestral = self.data[col_valor].resample('Q').mean()

        plt.figure(figsize=(10, 5))
        plt.plot(diario, label ="Diario")
        plt.plot(mensual, label="Mensual")
        plt.plot(trimestral, label="Trimestral")

        plt.legend()
        plt.title("Remuestreo")
        plt,xlabel("Fecha")
        plt.ylabel("Valor")
        plt.savefig("graficos/remuestreo.png")
        plt.show()

#Clase para EEG (.MAT)

class ArchivoEEG:
    def __init__(self, ruta):
        self.data = loadmat(ruta)
        self.ruta = ruta
        print("Archivo EEG (.MAT) cargado correctamente.")

        #ver variables
    def ver_llaves(self):
        print(whosmat(self.ruta))

        #suma de canales
    def sumar_canales(self, key, c1, c2, c3, inicio, fin):
        señal = self.data[key]

        #convertir a 2D si es necesario
        señal = np.squeeze(señal)
        suma = señal[c1, inicio:fin] + señal[c2, inicio:fin] + señal[c3, inicio:fin]
        tiempo = np.arange(inicio, fin) / 1000   # Asumiendo una frecuencia de muestreo de 1000 Hz

        fig, axs = plt.subplots(2, 1, figsize=(8, 6))

        axs[0].plot(tiempo, señal[c1, inicio:fin], label="Canal 1")
        axs[0].plot(tiempo, señal[c2, inicio:fin], label="Canal 2")
        axs[0].plot(tiempo, señal[c3, inicio:fin], label="Canal 3")
        axs[0].set_title("canales EEG")
        axs[0].set_ylabel("Microvoltios")
        axs[0].legend()

        axs[1].plot(tiempo, suma, label ="Suma", color="red")
        axs[1].set_title("Suma de canales")
        axs[1].set_xlabel("Segundos")
        axs[1].set_ylabel("Microvoltios")

        plt.tight_layout()
        plt.savefig("graficos/egg_suma.png")
        plt.show()

    #Promedio y desviación 
    def estadisticas(self, Key): 
        señal = self.data[Key]
        señal = np.squeeze(señal)

        promedio = np.mean(señal, axis=0)
        desviacion = np.std(señal, axis=0)

        fig, axs = plt.subplots(2, 1)

        axs[0].stem(promedio) 
        axs[0].set_title("Promedio")

        axs[1].stem(desviacion)
        axs[1].set_title("Desviación estándar")
        plt.tight_layout()
        plt.show()
        
        

        
